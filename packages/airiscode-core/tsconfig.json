{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "composite": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@lydell/node-pty": ["../../node_modules/@lydell/node-pty/node-pty.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "src/mcp/google-auth-provider.ts",
    "src/mcp/sa-impersonation-provider.ts"
  ]
}
